@startuml
skinparam backgroundColor transparent
actor User
participant Bot
participant "Branch Config" as Config
participant REST

User -> Bot: "Взять талон"
Bot -> Config: load branches
Config --> Bot: branches[]
Bot --> User: branch keyboard
User -> Bot: select branch
Bot -> REST: GET /branches/{id}/services
REST --> Bot: services[]
Bot --> User: services keyboard
User -> Bot: select service
Bot -> REST: POST /entryPoints/{entry_point_id}/visits
REST --> Bot: ticketId
Bot --> User: "Ваш талон: ..."
@enduml
