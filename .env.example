# =========================
# Telegram bot credentials
# =========================
API_TOKEN=

# =========================
# Queue providers (global fallback)
# =========================
# Глобальный fallback, если в ORCHESTRA_BRANCHES у отделения
# не указаны queue_system/base_url/login/password.
QUEUE_SYSTEM=orchestra

# Orchestra (fallback)
ORCHESTRA_URL=http://192.168.0.38:8080/
ORCHESTRA_LOGIN=superadmin
ORCHESTRA_PASSWORD=ulan

# Axioma (fallback)
# Адрес для отладки по вашему запросу:
AXIOMA_URL=http://192.168.8.40:8080/
AXIOMA_LOGIN=superadmin
AXIOMA_PASSWORD=ulan

# =========================
# Logging
# =========================
LOG_LEVEL=INFO

# =========================
# Legacy single-branch fallback
# Используется только если ORCHESTRA_BRANCHES пустой.
# =========================
BRANCH_ID=6
ORCHESTRA_ENTRY_POINT_ID=2
ORCHESTRA_BRANCH_CODE=NTR
ORCHESTRA_BRANCH_NAME=Основное отделение

# =========================
# Multi-branch mode (preferred)
# =========================
# Для каждого отделения можно указать:
# - queue_system: orchestra | axioma
# - base_url, login, password
ORCHESTRA_BRANCHES=[{"id":"6","name":"Нотариус","prefix":"NTR","entry_point_id":"2","queue_system":"orchestra","base_url":"http://192.168.0.38:8080/","login":"superadmin","password":"ulan"},{"id":"cd842979-3dc1-4505-a1ae-9a92f0622da2","name":"Банк \"Дубна\"","prefix":"DUB","entry_point_id":"f7ff91a7-a2a7-4b90-adaf-b2d38a24e0f2","queue_system":"axioma","base_url":"http://192.168.8.40:8080/","login":"superadmin","password":"ulan"}]

# =========================
# Service menu filtering
# =========================
SERVICE_BLACKLIST=Оплата услуг

# =========================
# Visit call message templates
# =========================
VISIT_CALL_TEMPLATE=🔔 Талон {ticketId}! Подойдите к окну {servicePointName} (№{servicePointId}).
ORCHESTRA_BRANCH_VISIT_CALL_TEMPLATES={"6":"🏛️ Нотариус: талон {ticketId}, пройдите к {servicePointName}.","DUB":"Банк Дубна: талон {ticket} -> {servicePointName}."}

# =========================
# Multi-service selection
# =========================
ORCHESTRA_MULTI_SERVICE_ENABLED=false
ORCHESTRA_BRANCH_MULTI_SERVICE_ENABLED={"6":true,"DUB":true}

# =========================
# Dialog flow order
# =========================
ORCHESTRA_FLOW_ORDER=ACTION_FIRST
