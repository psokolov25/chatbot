API_TOKEN=
ORCHESTRA_URL=http://127.0.0.1:8080/
ORCHESTRA_LOGIN=superadmin
ORCHESTRA_PASSWORD=ulan

# Legacy single-branch fallback (used when ORCHESTRA_BRANCHES is empty)
BRANCH_ID=6
ORCHESTRA_ENTRY_POINT_ID=2
ORCHESTRA_BRANCH_CODE=NTR
ORCHESTRA_BRANCH_NAME=Основное отделение

# Multi-branch mode (preferred)
ORCHESTRA_BRANCHES=[{"id":6,"name":"Центральное отделение","prefix":"NTR","entry_point_id":2},{"id":7,"name":"Северное отделение","prefix":"SVR","entry_point_id":3}]

# Optional service filtering (comma-separated)
SERVICE_BLACKLIST=Оплата услуг

# Visit call message templates
VISIT_CALL_TEMPLATE=🔔 Талон {ticketId}! Подойдите к окну {servicePointName} (№{servicePointId}). Если номер уже обслужен — обратитесь к администратору.
ORCHESTRA_BRANCH_VISIT_CALL_TEMPLATES={"6":"🏛️ Центральное отделение: талон {ticketId}, пройдите к {servicePointName} (окно {servicePointId}).","SVR":"🌐 Северное отделение: приглашаем талон {ticket}. Окно {servicePointId}."}
