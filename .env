# =========================
# Telegram bot credentials
# =========================
# Токен Telegram-бота от @BotFather.
# Обязательный параметр для запуска.
# Примеры:
# API_TOKEN=1234567890:AAExampleTokenFromBotFather
# API_TOKEN=<SECRET>
API_TOKEN=8263375262:AAEGdPIg4wgBoQCC8lDB-tSNPdQycVocT2s

# =========================
# Orchestra connection
# =========================
# Базовый URL Orchestra (с протоколом http/https).
# Рекомендуется завершать слешем, но код обработает и без него.
# Примеры:
# ORCHESTRA_URL=http://127.0.0.1:8080/
# ORCHESTRA_URL=http://orchestra.internal:8080
# ORCHESTRA_URL=https://orchestra.example.com/
ORCHESTRA_URL=http://192.168.0.38:8080/

# Логин/пароль для REST и CometD запросов в Orchestra.
# Примеры:
# ORCHESTRA_LOGIN=superadmin
# ORCHESTRA_LOGIN=bot_integration
ORCHESTRA_LOGIN=superadmin

# Примеры:
# ORCHESTRA_PASSWORD=ulan
# ORCHESTRA_PASSWORD=<SECRET>
ORCHESTRA_PASSWORD=ulan

# =========================
# Logging
# =========================
# Уровень логирования приложения.
# Допустимые/типичные значения: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Примеры:
# LOG_LEVEL=DEBUG
# LOG_LEVEL=INFO
# LOG_LEVEL=WARNING
LOG_LEVEL=INFO

# =========================
# Legacy single-branch fallback
# Используется ТОЛЬКО если ORCHESTRA_BRANCHES пустой.
# =========================
# Идентификатор филиала (целое число).
# Примеры: 6, 7, 101
BRANCH_ID=6

# Идентификатор entry point для создания визитов в филиале.
# Примеры: 1, 2, 5
ORCHESTRA_ENTRY_POINT_ID=2

# Короткий код филиала (prefix) для callback-команд и сопоставления событий.
# Примеры: NTR, SVR, SOUTH, BR01
ORCHESTRA_BRANCH_CODE=NTR

# Отображаемое название филиала в кнопках/интерфейсе.
# Примеры:
# ORCHESTRA_BRANCH_NAME=Основное отделение
# ORCHESTRA_BRANCH_NAME=Центральный офис
ORCHESTRA_BRANCH_NAME=Основное отделение

# =========================
# Multi-branch mode (preferred)
# =========================
# JSON-массив филиалов. Если заполнен, полностью заменяет fallback-режим выше.
# Каждый объект: {"id": int, "name": str, "prefix": str, "entry_point_id": int}
# Важно:
# - id должны быть уникальны
# - prefix должны быть уникальны
# - prefix лучше использовать короткий и стабильный (например NTR, SVR)
# Примеры:
# ORCHESTRA_BRANCHES=[{"id":6,"name":"Центральное отделение","prefix":"NTR","entry_point_id":2}]
ORCHESTRA_BRANCHES=[{"id":6,"name":"Нотариус","prefix":"NTR","entry_point_id":2},{"id":5,"name":"Сбербанк Минск","prefix":"SBR","entry_point_id":2}]
#ORCHESTRA_BRANCHES=

# =========================
# Service menu filtering
# =========================
# Список услуг для скрытия в меню, через запятую.
# Сопоставляется по internalName/name/id (в строковом виде).
# Примеры:
# SERVICE_BLACKLIST=Оплата услуг
# SERVICE_BLACKLIST=Оплата услуг,Консультация,123
# SERVICE_BLACKLIST=
SERVICE_BLACKLIST=Оплата услуг

# =========================
# Visit call message templates
# =========================
# Глобальный шаблон текста вызова посетителя.
# Поддерживаемые плейсхолдеры в шаблоне:
# - {ticketId} (или синоним {ticket})
# - {servicePointId}
# - {servicePointName}
# - {visitorId} (синоним для prm.TelegramCustomerId)
# - {visitorName} (синоним для prm.TelegramCustomerFullName)
# Примеры:
# VISIT_CALL_TEMPLATE=🔔 Талон {ticketId}! Подойдите к окну {servicePointName} (№{servicePointId}).
# VISIT_CALL_TEMPLATE=Клиент {ticket}, пройдите к рабочему месту {servicePointId}
VISIT_CALL_TEMPLATE=🔔 Талон {ticketId}! Подойдите к окну {servicePointName} (№{servicePointId}). Если номер уже обслужен — обратитесь к администратору.

# Переопределения шаблона по филиалу (JSON-объект): ключ = branchId ИЛИ prefix.
# Если ключ найден — используется этот шаблон вместо глобального VISIT_CALL_TEMPLATE.
# Примеры:
# ORCHESTRA_BRANCH_VISIT_CALL_TEMPLATES={"6":"🏛️ Центральное отделение: талон {ticketId}, пройдите к {servicePointName} (окно {servicePointId})."}
# ORCHESTRA_BRANCH_VISIT_CALL_TEMPLATES={"6":"Центр: {ticketId}","SVR":"Север: {ticket} -> окно {servicePointId}"}
ORCHESTRA_BRANCH_VISIT_CALL_TEMPLATES={"6":"🏛️ Нотариус: талон {ticketId}, пройдите к {servicePointName} (окно {servicePointId}).","SBR":"Сбербанк Минск: приглашаем талон {ticket}. Окно {servicePointName}."}

# =========================
# Multi-service selection for visit creation
# =========================
# Глобальное включение выбора нескольких услуг:
# true/false, также поддерживаются 1/0, yes/no, on/off.
# Примеры:
# ORCHESTRA_MULTI_SERVICE_ENABLED=true
# ORCHESTRA_MULTI_SERVICE_ENABLED=false
# ORCHESTRA_MULTI_SERVICE_ENABLED=1
ORCHESTRA_MULTI_SERVICE_ENABLED=false

# Переопределения multi-service по филиалу (JSON-объект): ключ = branchId ИЛИ prefix.
# Значения: true/false.
# Логика приоритета:
# 1) Если у филиала есть ключ в этом JSON — используется он.
# 2) Иначе берётся глобальное ORCHESTRA_MULTI_SERVICE_ENABLED.
# Примеры:
# ORCHESTRA_BRANCH_MULTI_SERVICE_ENABLED={"6":true}
# ORCHESTRA_BRANCH_MULTI_SERVICE_ENABLED={"6":true,"SVR":false,"8":true}
ORCHESTRA_BRANCH_MULTI_SERVICE_ENABLED={"6":true,"SBR":false}

# =========================
# Dialog flow order
# =========================
# Порядок шагов в диалоге:
# - ACTION_FIRST (по умолчанию): сначала выбор действия, затем филиал/услуга
# - BRANCH_FIRST: сначала выбор филиала, затем выбор действия
# Примеры:
# ORCHESTRA_FLOW_ORDER=ACTION_FIRST
# ORCHESTRA_FLOW_ORDER=BRANCH_FIRST
ORCHESTRA_FLOW_ORDER=ACTION_FIRST
